{
  "name": "@email-lint/react-email",
  "version": "0.2.0",
  "description": "Lint react-email components for client compatibility using email-lint.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist coverage",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "dependencies": {
    "email-lint": "workspace:*"
  },
  "peerDependencies": {
    "@react-email/render": ">=1.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@react-email/render": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@react-email/render": "^1.0.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.8",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "keywords": [
    "email-lint",
    "react-email",
    "lint",
    "email",
    "compatibility"
  ],
  "author": "Jarod Stewart",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stewartjarod/email-lint.git",
    "directory": "packages/react-email"
  },
  "homepage": "https://github.com/stewartjarod/email-lint/tree/main/packages/react-email#readme",
  "bugs": "https://github.com/stewartjarod/email-lint/issues",
  "publishConfig": {
    "access": "public"
  }
}
