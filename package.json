{
  "name": "email-lint-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "8.0.8"
    }
  },
  "packageManager": "pnpm@9.0.0",
  "keywords": [
    "email",
    "lint",
    "email-lint",
    "caniemail",
    "html-email"
  ],
  "author": "Jarod",
  "license": "MIT"
}
